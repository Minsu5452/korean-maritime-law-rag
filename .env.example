# law.go.kr 수집과 실시간 조회.
MLR_LAW_OC=

# 로컬 인덱스 서비스. docker-compose.yml의 기본값과 맞춰 둡니다.
MLR_CACHE_DIR=data/cache/raw
MLR_BM25_PATH=data/bm25.pkl
MLR_QDRANT_URL=http://localhost:6333
MLR_NEO4J_URI=bolt://localhost:7687
MLR_NEO4J_USER=neo4j
MLR_NEO4J_PASSWORD=marinerag

# LangGraph 답변 생성과 에이전트 평가.
OPENAI_API_KEY=
MLR_LLM_MODEL=openai:gpt-4o-mini
MLR_JUDGE_MODEL=openai:gpt-4o
MLR_LLM_TEMPERATURE=0
MLR_LLM_REASONING_EFFORT=

# 검색과 인덱싱.
MLR_EMBEDDING_MODEL=nlpai-lab/KURE-v1
MLR_EMBEDDING_DEVICE=cpu
MLR_EMBEDDING_CACHE=data/embeddings/kure-v1-articles.npz
MLR_RERANK=false
MLR_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
MLR_RERANKER_DEVICE=cpu
MLR_TOP_K=10
MLR_RRF_K=60
MLR_GRAPH_HOPS=1
MLR_AS_OF=
MLR_ENABLE_LAW_API_FALLBACK=false

# Langfuse 추적. `make up`으로 로컬 서비스를 함께 띄울 수 있습니다.
MLR_LANGFUSE_ENABLED=false
MLR_LANGFUSE_HOST=http://localhost:3000
MLR_LANGFUSE_PUBLIC_KEY=pk-lf-localdev
MLR_LANGFUSE_SECRET_KEY=sk-lf-localdev
